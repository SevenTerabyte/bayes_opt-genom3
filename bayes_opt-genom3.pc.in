# pkg-config file for bayes_opt interface and codels library
#
prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@
datarootdir=@datarootdir@
idldir=@datadir@/idl

Name: bayes_opt-genom3
Description: bayes_opt interface and codels library
Version: @PACKAGE_VERSION@
Requires: @requires_SPEC@
Cflags: -I${includedir} -I${idldir}
Libs: -L${libdir} -lbayes_opt_codels
Libs.private: @codels_requires_LIBS@
