# pkg-config file for bayes_opt interface and codels library
#
prefix=
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include
datarootdir=${prefix}/share
idldir=${datarootdir}/idl

Name: bayes_opt-genom3
Description: bayes_opt interface and codels library
Version: 0.8
Requires: openrobots2-idl >= 2.0, genom3 >= 2.99.26
Cflags: -I${includedir} -I${idldir}
Libs: -L${libdir} -lbayes_opt_codels
Libs.private: 
